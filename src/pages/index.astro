---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";
---

<Layout>
  <!-- ─── Hero Section ─────────────────────────────────────────── -->
  <section class="pt-[calc(80px+4rem)] pb-24 bg-[#1c1c1e] text-[#faf7f9]">
    <div
      class="max-w-[1200px] mx-auto px-4 lg:px-8 grid grid-cols-1 lg:grid-cols-2 items-center gap-16 text-center lg:text-left"
    >
      <!-- Content -->
      <div class="max-w-[540px] mx-auto lg:mx-0">
        <span
          class="border border-[#faf7f9] text-[#faf7f9] px-3 py-1 rounded-full text-[0.625rem] uppercase tracking-[0.1em] font-bold mb-8 inline-block"
        >
          {siteConfig.hero.badge}
        </span>

        <h1
          class="text-[clamp(3rem,8vw,4.5rem)] leading-[1.1] font-bold tracking-[-0.04em] mb-8 text-[#faf7f9]"
        >
          {siteConfig.hero.title}
        </h1>

        <p class="text-lg leading-relaxed text-white/70 mb-12">
          {siteConfig.hero.subtitle}
        </p>

        <div class="flex gap-6 justify-center lg:justify-start flex-wrap">
          {
            siteConfig.hero.ctas.map((cta) => (
              <a
                href={cta.href}
                style={cta.primary ? "color: #1c1c1e" : ""}
                class={[
                  "inline-flex items-center justify-center px-8 py-4 w-full md:w-auto rounded-xl font-semibold text-sm tracking-[0.05em] uppercase transition-all duration-300 cursor-pointer",
                  cta.primary
                    ? "bg-white hover:-translate-y-0.5 hover:shadow-xl hover:opacity-90"
                    : "bg-transparent text-[#faf7f9] border border-white/30 hover:bg-white/10",
                ].join(" ")}
              >
                {cta.text}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Image -->
      <div class="flex justify-center">
        <div class="w-full max-w-[500px] animate-float">
          <img
            src={siteConfig.hero.image}
            alt="iPhone 16 Pro Cinematic Shot"
            width="600"
            height="auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Trust Badges ──────────────────────────────────────────── -->
  <section class="py-24 bg-[#f2f4f6]">
    <div class="max-w-[1200px] mx-auto px-4 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {
          siteConfig.trustBadges.map((badge) => (
            <div class="text-center flex flex-col items-center p-8 bg-white rounded-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_15px_30px_rgba(0,0,0,0.05)]">
              <div class="mb-6 text-[#1c1c1e]">
                {badge.icon === "check-circle" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                )}
                {badge.icon === "shield-check" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                )}
                {badge.icon === "leaf" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
                    <path d="M2 21c0-3 1.85-5.36 5.08-6C10.9 14.36 12 15 13 18c1.23 3.68-.35 5-3 5-4 0-8-1-8-2Z" />
                  </svg>
                )}
              </div>

              <h3 class="text-lg font-bold mb-4 text-[#1c1c1e]">
                {badge.title}
              </h3>
              <p class="text-sm text-[#596065] leading-relaxed">
                {badge.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─── New Arrivals ──────────────────────────────────────────── -->
  <section id="new-arrivals" class="md:py-32 py-4">
    <div class="max-w-[1200px] mx-auto px-4 lg:px-8">
      <header
        class="flex flex-col md:flex-row justify-between md:items-end items-start mb-16 gap-2 md:gap-0"
      >
        <div>
          <span
            class="text-xs uppercase tracking-[0.2em] font-extrabold text-[#596065] block mb-4"
            >Gallery</span
          >
          <h2
            class="text-[clamp(2rem,5vw,3rem)] tracking-[-0.03em] font-bold text-[#1c1c1e] leading-[1.1]"
          >
            {siteConfig.newArrivals.title}
          </h2>
        </div>
        <a
          href={siteConfig.newArrivals.viewAllLink}
          class="font-bold border-b-2 border-[#1c1c1e] pb-1 text-[#1c1c1e] whitespace-nowrap"
        >
          View all New <span>→</span>
        </a>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          siteConfig.newArrivals.products.map((product) => (
            <div class="group bg-[#f2f4f6] rounded-xl p-6 relative overflow-hidden transition-all duration-300 hover:bg-[#e4e9ee] flex flex-col h-full">
              {product.badge && (
                <span class="absolute top-4 right-4 bg-[#1c1c1e] text-[#faf7f9] px-3 py-1 rounded-full text-[0.625rem] font-extrabold z-10">
                  {product.badge}
                </span>
              )}

              <div class="p-8 flex-1 flex items-center justify-center">
                <img
                  src={product.image}
                  alt={product.name}
                  class="max-h-[280px] object-contain transition-transform duration-500 group-hover:scale-105"
                />
              </div>

              <div class="pt-4 px-2">
                <span class="text-xs text-[#596065] mb-2 block">
                  {product.color}
                </span>
                <h3 class="text-xl font-bold mb-2 text-[#1c1c1e]">
                  {product.name}
                </h3>
                <p class="font-bold mb-6">From ${product.price}</p>
                <button class="w-full py-4 border border-[#1c1c1e] bg-transparent font-bold text-xs tracking-[0.1em] rounded-xl cursor-pointer transition-all duration-300 hover:bg-[#1c1c1e] hover:text-[#faf7f9]">
                  BUY NOW
                </button>
              </div>
            </div>
          ))
        }

        <!-- Editorial Card -->
        <div
          class="bg-[#1c1c1e] text-[#faf7f9] rounded-xl flex flex-col overflow-hidden scale-[1.07]"
        >
          <div class="p-12">
            <h3
              class="text-white text-[2.25rem] leading-[1.1] font-bold mb-6 max-w-[200px]"
            >
              {siteConfig.newArrivals.editorial.title}
            </h3>
            <p class="text-sm opacity-70 leading-relaxed">
              {siteConfig.newArrivals.editorial.description}
            </p>
          </div>
          <div class="flex-1 flex items-end justify-center overflow-hidden">
            <img
              src={siteConfig.newArrivals.editorial.image}
              alt="Editorial shot"
              class="w-full object-contain block"
              style="transform: translate(7px, -25px); scale: 1.5;"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Pre-Owned ─────────────────────────────────────────────── -->
  <section id="pre-owned" class="md:py-32 py-4 bg-[#f9f9fb]">
    <div class="max-w-[1200px] mx-auto px-4 lg:px-8">
      <header
        class="flex flex-col md:flex-row justify-between md:items-end items-start gap-2 md:gap-0 mb-16"
      >
        <div>
          <span
            class="text-xs uppercase tracking-[0.2em] font-extrabold text-[#596065] block mb-4"
            >Curated</span
          >
          <h2
            class="text-[clamp(2rem,5vw,3rem)] tracking-[-0.03em] font-bold text-[#1c1c1e] leading-[1.1]"
          >
            {siteConfig.preOwned.title}
          </h2>
        </div>
        <span
          class="text-xs font-bold text-[#596065] px-4 py-2 bg-[#ebeef2] rounded-full"
        >
          {siteConfig.preOwned.filterLabel}
        </span>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8">
        <!-- Spotlight Card -->
        <div
          class="bg-[#f2f4f6] rounded-xl grid grid-cols-1 md:grid-cols-2 overflow-hidden"
        >
          <div class="p-12 lg:p-20 flex flex-col justify-center">
            <h3
              class="text-[2.5rem] leading-[1.1] font-bold mb-6 text-[#1c1c1e]"
            >
              {siteConfig.preOwned.spotlight.name}
            </h3>
            <p class="text-base text-[#596065] leading-relaxed mb-8">
              {siteConfig.preOwned.spotlight.description}
            </p>
            <p class="text-2xl font-bold mb-12">
              ${siteConfig.preOwned.spotlight.price}
            </p>
            <button
              class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-[#1c1c1e] text-[#faf7f9] font-semibold text-sm tracking-[0.05em] uppercase border-none cursor-pointer transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:opacity-90"
            >
              ADD TO COLLECTION
            </button>
          </div>
          <div class="flex items-center justify-center overflow-hidden p-8">
            <img
              src={siteConfig.preOwned.spotlight.image}
              alt={siteConfig.preOwned.spotlight.name}
              class="max-h-full w-auto object-contain"
              style="filter: drop-shadow(0 20px 40px rgba(0,0,0,0.1));"
            />
          </div>
        </div>

        <!-- Secondary Products -->
        <div class="flex flex-col gap-8 h-full">
          {
            siteConfig.preOwned.products.map((product) => (
              <div class="bg-[#f2f4f6] rounded-xl p-6 flex flex-row items-center gap-6 transition-all duration-300 hover:bg-[#e4e9ee] flex-1">
                <div class="w-[100px] h-[100px] shrink-0 flex items-center justify-center">
                  <img
                    src={product.image}
                    alt={product.name}
                    class="max-h-[80px] object-contain"
                  />
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-2 text-[#1c1c1e]">
                    {product.name}
                  </h3>
                  <p class="font-bold">${product.price}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Contact / WhatsApp ────────────────────────────────────── -->
  <section id="support" class="md:py-32 py-4 bg-[#f2f4f6]">
    <div class="max-w-[1200px] mx-auto px-4 lg:px-8">
      <div
        class="bg-white rounded-xl p-12 md:p-20 text-center max-w-[900px] mx-auto"
      >
        <span
          class="text-xs uppercase tracking-[0.2em] font-extrabold text-[#596065] block mb-4"
        >
          Personal Service
        </span>
        <h2
          class="md:text-[3rem] text-[2rem] leading-[1.1] font-bold mb-6 text-[#1c1c1e]"
        >
          {siteConfig.contact.sectionTitle}
        </h2>
        <p class="text-lg text-[#596065] mb-16 max-w-[600px] mx-auto">
          {siteConfig.contact.sectionDescription}
        </p>

        <div class="flex flex-col items-center gap-16">
          <a
            href={`https://wa.me/${siteConfig.whatsappNumber.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(siteConfig.whatsappMessage)}`}
            class="inline-flex items-center gap-4 bg-[#25d366] px-12 py-6 rounded-xl font-bold transition-all duration-300 hover:scale-105 hover:shadow-[0_15px_30px_rgba(37,211,102,0.2)]"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="#1c1c1e"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 .004 5.408 0 12.044c0 2.123.555 4.191 1.608 6.01L0 24l6.117-1.605a11.803 11.803 0 0 0 5.925 1.61h.005c6.632 0 12.042-5.408 12.047-12.044a11.8 11.8 0 0 0-3.522-8.498"
              ></path>
            </svg>
            {siteConfig.contact.whatsappCtaText}
          </a>

          <div
            class="pt-12 border-t border-[#f2f4f6] w-full flex flex-col gap-2 items-center"
          >
            <p class="font-bold text-[#1c1c1e]">Visitanos en</p>
            <p class="text-[#596065]">{siteConfig.address}</p>
            <p>
              <a
                href={`mailto:${siteConfig.email}`}
                class="font-bold text-[#1c1c1e]"
              >
                {siteConfig.email}
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
