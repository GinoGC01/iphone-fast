---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config";
---

<Layout>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-content">
        <span class="badge">{siteConfig.hero.badge}</span>
        <h1>{siteConfig.hero.title}</h1>
        <p class="subtitle">{siteConfig.hero.subtitle}</p>
        <div class="hero-actions">
          {
            siteConfig.hero.ctas.map((cta) => (
              <a
                href={cta.href}
                class={`btn ${cta.primary ? "btn-primary" : "btn-secondary"}`}
              >
                {cta.text}
              </a>
            ))
          }
        </div>
      </div>
      <div class="hero-image">
        <div class="image-wrapper">
          <img
            src={siteConfig.hero.image}
            alt="iPhone 16 Pro Cinematic Shot"
            width="600"
            height="auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges Section -->
  <section class="trust-badges">
    <div class="container">
      <div class="badges-grid">
        {
          siteConfig.trustBadges.map((badge) => (
            <div class="badge-card">
              <div class="badge-icon">
                {badge.icon === "check-circle" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="10" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                )}
                {badge.icon === "shield-check" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                    <path d="m9 12 2 2 4-4" />
                  </svg>
                )}
                {badge.icon === "leaf" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z" />
                    <path d="M2 21c0-3 1.85-5.36 5.08-6C10.9 14.36 12 15 13 18c1.23 3.68-.35 5-3 5-4 0-8-1-8-2Z" />
                  </svg>
                )}
              </div>
              <h3>{badge.title}</h3>
              <p>{badge.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- New Arrivals Section -->
  <section id="new-arrivals" class="product-section">
    <div class="container">
      <header class="section-header">
        <div>
          <span class="section-tag">Gallery</span>
          <h2>{siteConfig.newArrivals.title}</h2>
        </div>
        <a href={siteConfig.newArrivals.viewAllLink} class="view-all"
          >View all New <span class="arrow">→</span></a
        >
      </header>

      <div class="arrivals-grid">
        {
          siteConfig.newArrivals.products.map((product) => (
            <div class="product-card">
              {product.badge && <span class="card-badge">{product.badge}</span>}
              <div class="card-image">
                <img src={product.image} alt={product.name} />
              </div>
              <div class="card-info">
                <span class="product-color">{product.color}</span>
                <h3>{product.name}</h3>
                <p class="price">From ${product.price}</p>
                <button class="buy-btn">BUY NOW</button>
              </div>
            </div>
          ))
        }

        <div class="editorial-card">
          <div class="editorial-content">
            <h3>{siteConfig.newArrivals.editorial.title}</h3>
            <p>{siteConfig.newArrivals.editorial.description}</p>
          </div>
          <div class="editorial-image">
            <img
              src={siteConfig.newArrivals.editorial.image}
              alt="Editorial shot"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pre-Owned Section -->
  <section id="pre-owned" class="product-section pre-owned">
    <div class="container">
      <header class="section-header">
        <div>
          <span class="section-tag">Curated</span>
          <h2>{siteConfig.preOwned.title}</h2>
        </div>
        <span class="condition-badge">{siteConfig.preOwned.filterLabel}</span>
      </header>

      <div class="preowned-grid">
        <div class="spotlight-card">
          <div class="spotlight-info">
            <h3>{siteConfig.preOwned.spotlight.name}</h3>
            <p class="description">
              {siteConfig.preOwned.spotlight.description}
            </p>
            <p class="price">${siteConfig.preOwned.spotlight.price}</p>
            <button class="btn btn-primary">ADD TO COLLECTION</button>
          </div>
          <div class="spotlight-image">
            <img
              src={siteConfig.preOwned.spotlight.image}
              alt={siteConfig.preOwned.spotlight.name}
            />
          </div>
        </div>

        <div class="secondary-products">
          {
            siteConfig.preOwned.products.map((product) => (
              <div class="product-card mini">
                <div class="card-image">
                  <img src={product.image} alt={product.name} />
                </div>
                <div class="card-info">
                  <h3>{product.name}</h3>
                  <p class="price">${product.price}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- WhatsApp Contact Section -->
  <section id="support" class="contact-section">
    <div class="container">
      <div class="contact-card">
        <div class="contact-info">
          <span class="section-tag">Personal Service</span>
          <h2>{siteConfig.contact.sectionTitle}</h2>
          <p>{siteConfig.contact.sectionDescription}</p>

          <div class="contact-methods">
            <a
              href={`https://wa.me/${siteConfig.whatsappNumber.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(siteConfig.whatsappMessage)}`}
              class="whatsapp-btn"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="white"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 .004 5.408 0 12.044c0 2.123.555 4.191 1.608 6.01L0 24l6.117-1.605a11.803 11.803 0 0 0 5.925 1.61h.005c6.632 0 12.042-5.408 12.047-12.044a11.8 11.8 0 0 0-3.522-8.498"
                ></path>
              </svg>
              {siteConfig.contact.whatsappCtaText}
            </a>

            <div class="personal-consultation">
              <p><strong>Visitanos en</strong></p>
              <p>{siteConfig.address}</p>
              <p>
                <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    padding-top: calc(var(--nav-height) + 4rem);
    padding-bottom: 6rem;
    background: var(--primary);
    color: var(--on-primary);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }

  .hero-content {
    max-width: 540px;
  }

  .hero-content .badge {
    border: 1px solid var(--on-primary);
    color: var(--on-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    margin-bottom: 2rem;
    display: inline-block;
  }

  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 4.5rem);
    letter-spacing: -0.04em;
    margin-bottom: 2rem;
    color: var(--on-primary);
  }

  .hero-content .subtitle {
    font-size: 1.125rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 3rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
  }

  .hero-actions .btn-primary {
    background-color: var(--surface-container-lowest);
    color: var(--primary);
  }

  .hero-actions .btn-secondary {
    color: var(--on-primary);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .hero-image {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .image-wrapper {
    width: 100%;
    max-width: 500px;
    position: relative;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* Trust Badges */
  .trust-badges {
    padding: 6rem 0;
    background-color: var(--surface-container-low);
  }

  .badges-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  .badge-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
    background-color: var(--surface-container-lowest);
    border-radius: var(--roundness);
    transition: all 0.3s ease;
  }

  .badge-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);
  }

  .badge-icon {
    margin-bottom: 1.5rem;
    color: var(--primary);
  }

  .badge-card h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
  }

  .badge-card p {
    font-size: 0.875rem;
    color: var(--on-surface-variant);
    line-height: 1.5;
  }

  /* Product Sections */
  .product-section {
    padding: 8rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
  }

  .section-tag {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 800;
    color: var(--on-surface-variant);
    display: block;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.03em;
  }

  .view-all {
    font-weight: 700;
    border-bottom: 2px solid var(--primary);
    padding-bottom: 4px;
  }

  .arrivals-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  /* Product Cards */
  .product-card {
    background-color: var(--surface-container-low);
    border-radius: var(--roundness);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .product-card:hover {
    background-color: var(--surface-container-high);
  }

  .card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background-color: var(--primary);
    color: var(--on-primary);
    padding: 0.25rem 0.75rem;
    border-radius: 50px;
    font-size: 0.625rem;
    font-weight: 800;
    z-index: 2;
  }

  .card-image {
    padding: 2rem;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-image img {
    max-height: 280px;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .product-card:hover .card-image img {
    transform: scale(1.05);
  }

  .card-info {
    padding: 1rem 0.5rem;
  }

  .product-color {
    font-size: 0.75rem;
    color: var(--on-surface-variant);
    margin-bottom: 0.5rem;
    display: block;
  }

  .card-info h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .price {
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .buy-btn {
    width: 100%;
    padding: 1rem;
    border: 1px solid var(--primary);
    background: transparent;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    border-radius: var(--roundness);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .buy-btn:hover {
    background-color: var(--primary);
    color: var(--on-primary);
  }

  /* Editorial Card */
  .editorial-card {
    background-color: var(--primary);
    color: var(--on-primary);
    border-radius: var(--roundness);
    grid-column: span 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .editorial-content {
    padding: 3rem;
  }

  .editorial-content h3 {
    color: white;
    font-size: 2.25rem;
    margin-bottom: 1.5rem;
    max-width: 200px;
  }

  .editorial-content p {
    font-size: 0.875rem;
    opacity: 0.7;
    line-height: 1.6;
  }

  .editorial-image {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    overflow: hidden;
  }

  .editorial-image img {
    width: 100%;
    object-fit: contain;
    display: block;
    transform: translate(7px, -25px);
    scale: 1.5;
  }

  /* Pre-owned grid */
  .pre-owned {
    background-color: var(--bg-color);
  }

  .condition-badge {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--on-surface-variant);
    padding: 0.5rem 1rem;
    background: var(--surface-container);
    border-radius: 50px;
  }

  .preowned-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
  }

  .spotlight-card {
    grid-column: span 1;
    background-color: var(--surface-container-low);
    border-radius: var(--roundness);
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .spotlight-info {
    padding: 5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .spotlight-info h3 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .description {
    font-size: 1rem;
    color: var(--on-surface-variant);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .spotlight-info .price {
    font-size: 1.5rem;
    margin-bottom: 3rem;
  }

  .spotlight-image img {
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.1));
    max-height: 100%;
  }

  .secondary-products {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .mini {
    flex-direction: row;
    align-items: center;
    padding: 1rem;
    gap: 1.5rem;
  }

  .mini .card-image {
    padding: 0;
    width: 100px;
    height: 100px;
  }

  .mini .card-image img {
    max-height: 80px;
  }

  /* Contact Section */
  .contact-section {
    padding: 8rem 0;
    background-color: var(--surface-container-low);
  }

  .contact-card {
    background-color: var(--surface-container-lowest);
    border-radius: var(--roundness);
    padding: 5rem;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .contact-info h2 {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .contact-info p {
    font-size: 1.125rem;
    color: var(--on-surface-variant);
    margin-bottom: 4rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  .whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background-color: #25d366;
    color: white;
    padding: 1.5rem 3rem;
    border-radius: var(--roundness);
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .whatsapp-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 15px 30px rgba(37, 211, 102, 0.2);
  }

  .personal-consultation {
    padding: 3rem;
    border-top: 1px solid var(--surface-container-low);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .personal-consultation a {
    font-weight: 700;
    color: var(--primary);
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content {
      margin: 0 auto;
    }
    .hero-actions {
      justify-content: center;
    }
    .arrivals-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .editorial-card {
      grid-column: span 2;
    }
    .preowned-grid {
      grid-template-columns: 1fr;
    }
    .spotlight-card {
      grid-template-columns: 1fr;
    }
    .spotlight-info {
      padding: 3rem;
    }
  }

  @media (max-width: 768px) {
    .badges-grid {
      grid-template-columns: 1fr;
    }
    .arrivals-grid {
      grid-template-columns: 1fr;
    }
    .editorial-card {
      grid-column: span 1;
    }
    .contact-card {
      padding: 2rem;
    }
  }
</style>
