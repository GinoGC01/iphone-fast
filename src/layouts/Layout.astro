---
import { siteConfig } from "../config";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteConfig.siteName,
  description = siteConfig.siteDescription,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {siteConfig.siteTagline}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body
    class="font-[Inter,system-ui,sans-serif] bg-[#f9f9fb] text-[#2d3338] antialiased scroll-smooth"
  >
    <!-- Navigation Bar -->
    <nav
      class="h-20 fixed top-0 left-0 right-0 z-[1000] bg-white backdrop-blur-xl border-b border-black/5 flex items-center"
    >
      <div
        class="max-w-[1200px] w-full mx-auto px-8 flex justify-between items-center"
      >
        <a
          href="/"
          class="font-extrabold text-xl tracking-tight text-[#1c1c1e] flex items-center gap-3"
        >
          <img
            src="/assets/logo.png"
            alt="Logo"
            class="h-10 w-10 object-contain"
          />
          {siteConfig.siteName}
        </a>

        <ul class="hidden md:flex gap-10 list-none">
          {
            siteConfig.nav.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-medium text-[#596065] hover:text-[#1c1c1e] transition-colors duration-200 no-underline"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="flex gap-2">
          <button
            class="bg-transparent border-none text-[#1c1c1e] cursor-pointer p-2 rounded-full hover:bg-[#ebeef2] transition-colors duration-200"
            aria-label="Search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </button>
          <button
            class="bg-transparent border-none text-[#1c1c1e] cursor-pointer p-2 rounded-full hover:bg-[#ebeef2] transition-colors duration-200"
            aria-label="Cart"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="8" cy="21" r="1"></circle>
              <circle cx="19" cy="21" r="1"></circle>
              <path
                d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"
              ></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-[#ebeef2]">
      <!-- Benefits Bar -->
      <div class="py-16 border-b border-[#f2f4f6]">
        <div class="max-w-[1200px] mx-auto px-4 lg:px-8">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            {
              siteConfig.benefits.map((benefit) => (
                <div class="flex flex-col items-center text-center gap-4">
                  <span class="w-12 h-12 bg-[#f2f4f6] rounded-full flex items-center justify-center text-[#1c1c1e] shrink-0">
                    {benefit.icon === "truck" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M5 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                        <path d="M19 18a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                        <path d="M13 18H7V6h11v5h4v5h-3" />
                        <path d="M13 18h3" />
                        <path d="M13 6H7" />
                      </svg>
                    )}
                    {benefit.icon === "rotate-ccw" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                        <path d="M3 3v5h5" />
                      </svg>
                    )}
                    {benefit.icon === "headset" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21 14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H3a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h5l3 3 3-3h5Z" />
                        <path d="M9 10v.01" />
                        <path d="M15 10v.01" />
                      </svg>
                    )}
                    {benefit.icon === "lock" && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <rect
                          width="18"
                          height="11"
                          x="3"
                          y="11"
                          rx="2"
                          ry="2"
                        />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                      </svg>
                    )}
                  </span>
                  <span class="text-sm font-semibold text-[#1c1c1e]">
                    {benefit.title}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Footer Bottom -->
      <div class="py-12 max-w-[1200px] mx-auto px-4 lg:px-8">
        <div
          class="flex flex-col md:flex-row justify-between items-center gap-6 flex-wrap"
        >
          <p class="text-xs text-[#596065]">{siteConfig.footer.copyright}</p>
          <div class="flex flex-col md:flex-row gap-4 md:gap-8 items-center">
            {
              siteConfig.footer.legalLinks.map((link) => (
                <a
                  href={link.href}
                  class="text-xs text-[#596065] hover:underline no-underline"
                >
                  {link.name}
                </a>
              ))
            }
          </div>
          <div class="flex gap-6">
            {
              siteConfig.footer.socials.map((social) => (
                <a
                  href={social.href}
                  aria-label={social.name}
                  class="text-xs text-[#596065] hover:text-[#1c1c1e] transition-colors no-underline"
                >
                  {social.name}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </footer>

    <!-- WhatsApp Floating Button & Chat Window -->
    <div class="fixed bottom-[30px] right-[30px] z-[1001]">
      <!-- Chat Window -->
      <div
        class="whatsapp-chat-window absolute bottom-20 right-0 w-80 bg-white rounded-[20px] shadow-[0_20px_40px_rgba(0,0,0,0.15)] overflow-hidden border border-black/5"
        id="whatsappChat"
      >
        <div
          class="bg-[#1c1c1e] text-white px-6 py-5 flex justify-between items-center"
        >
          <div class="flex items-center gap-3">
            <img
              src="/assets/logo.png"
              alt="Logo"
              class="w-8 h-8 object-contain bg-white rounded-full p-0.5"
            />
            <div class="flex flex-col">
              <span class="text-sm font-bold"
                >{siteConfig.siteName} Support</span
              >
              <span class="text-[0.625rem] opacity-70">En línea</span>
            </div>
          </div>
          <button
            class="bg-transparent border-none text-white cursor-pointer opacity-70 hover:opacity-100 transition-opacity duration-200"
            id="closeChat"
            aria-label="Cerrar chat"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>

        <div class="p-6 bg-[#f7f9fb]">
          <p
            class="bg-white p-4 rounded-[0_15px_15px_15px] text-sm leading-relaxed shadow-sm"
          >
            ¡Hola! 👋 Bienvenido al Iphone Fast. En qué podemos ayudarte hoy?
          </p>
        </div>

        <div class="px-6 pb-6 bg-[#f7f9fb]">
          <button
            class="w-full bg-[#25d366] text-white border-none py-4 rounded-xl font-bold text-sm flex items-center justify-center gap-2 cursor-pointer transition-all duration-300 hover:bg-[#1ebe57] hover:-translate-y-0.5 hover:shadow-[0_5px_15px_rgba(37,211,102,0.2)]"
            id="sendWhatsApp"
          >
            <span>Enviar mensaje</span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 .004 5.408 0 12.044c0 2.123.555 4.191 1.608 6.01L0 24l6.117-1.605a11.803 11.803 0 0 0 5.925 1.61h.005c6.632 0 12.042-5.408 12.047-12.044a11.8 11.8 0 0 0-3.522-8.498"
              ></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- Float Button -->
      <button
        class="wa-bounce-btn bg-[#25d366] w-[60px] h-[60px] rounded-full flex items-center justify-center shadow-[0_10px_25px_rgba(37,211,102,0.3)] border-none cursor-pointer transition-transform duration-300 hover:scale-110"
        id="whatsappBtn"
        aria-label="Abrir chat de WhatsApp"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="white"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 .004 5.408 0 12.044c0 2.123.555 4.191 1.608 6.01L0 24l6.117-1.605a11.803 11.803 0 0 0 5.925 1.61h.005c6.632 0 12.042-5.408 12.047-12.044a11.8 11.8 0 0 0-3.522-8.498"
          ></path>
        </svg>
      </button>
    </div>

    <script
      is:inline
      define:vars={{
        whatsappNumber: siteConfig.whatsappNumber,
        whatsappMessage: siteConfig.whatsappMessage,
      }}
    >
      const whatsappBtn = document.getElementById("whatsappBtn");
      const whatsappChat = document.getElementById("whatsappChat");
      const closeChat = document.getElementById("closeChat");
      const sendWhatsApp = document.getElementById("sendWhatsApp");

      whatsappBtn.addEventListener("click", () => {
        whatsappChat.classList.toggle("active");
      });
      closeChat.addEventListener("click", () => {
        whatsappChat.classList.remove("active");
      });
      sendWhatsApp.addEventListener("click", () => {
        const cleanNumber = whatsappNumber.replace(/[^0-9]/g, "");
        const url = `https://wa.me/${cleanNumber}?text=${encodeURIComponent(whatsappMessage)}`;
        window.open(url, "_blank");
        whatsappChat.classList.remove("active");
      });
      document.addEventListener("click", (event) => {
        if (
          !whatsappChat.contains(event.target) &&
          !whatsappBtn.contains(event.target)
        ) {
          whatsappChat.classList.remove("active");
        }
      });
    </script>
  </body>
</html>

<style is:global>
  /* Base resets not covered by Tailwind preflight */
  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  a {
    text-decoration: none;
    color: inherit;
  }
  ul {
    list-style: none;
  }
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* Custom keyframes */
  @keyframes wa-bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }
  .wa-bounce-btn {
    animation: wa-bounce 2s infinite;
  }

  /* WhatsApp chat toggle — requires JS .active class */
  .whatsapp-chat-window {
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .whatsapp-chat-window.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>
